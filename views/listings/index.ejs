<% layout("/layouts/boilerplate") %>
<body>
    <style>
        #filters{
    display: flex;
    flex-wrap: wrap;
    }
    .filter{
        text-align: center;
        margin-right: 2rem;
        margin-top: 2rem;
    }
    .filter:hover{
        opacity: 0.8;
        cursor: pointer;
    }
    .filter p{
        font-size: 0.8rem;
    }
    .tax-info{
      display: none;
    }
    .tax-toogle{
      border: 1px solid black;
      border-radius: 1rem;
      height: 3.5rem;
      padding: 1rem;
    }
    </style>

    <div id="filters">
        <div class="filter">
            <i class="fa-solid fa-fire"></i>
           <p> Trending </p>
        </div>
        <div class="filter">
           <i class="fa-solid fa-bed"></i>
          <p> Rooms</p>
        </div>
         <div class="filter">
           <i class="fa-solid fa-mountain-city"></i>
          <p>Hike</p>
        </div>
         <div class="filter">
           <i class="fa-solid fa-person-swimming"></i>
          <p> Swim</p>
        </div>
        <div class="filter">
           <i class="fa-solid fa-hippo"></i>
          <p> WildLife</p>
        </div>
        <div class="filter">
           <i class="fa-brands fa-fort-awesome"></i>
          <p>Historical</p>
        </div>
        <div class="filter">
           <i class="fa-solid fa-mountain"></i>
          <p>mountain</p>
        </div>
         <div class="filter">
           <i class="fa-solid fa-person-running"></i>
          <p> Outdoor</p>
        </div>
        <div class="filter">
           <i class="fa-solid fa-city"></i>
          <p>Iconic cities</p>
        </div>
        <div class="filter">
           <i class="fa-solid fa-mountain"></i>
          <p>Surfing</p>
        </div>
        <div class="filter">
           <i class="fa-solid fa-snowman"></i>
          <p>Arctic</p>
        </div>
        <div class="filter">
           <i class="fa-solid fa-umbrella-beach"></i>
          <p>Beaches</p>
        </div>
        <div class="filter">
           <i class="fa-solid fa-face-grin-stars"></i>
          <p>OMG!</p>
        </div>
        <div class="filter">
           <i class="fa-solid fa-water"></i>
          <p>Lakefront</p>
        </div>
        <div class="filter">
           <i class="fa-solid fa-cow"></i>
          <p>farms</p>
        </div>
        <div class="filter">
           <div><i class="fa-solid fa-pizza-slice"></i></div>
          <p>Food junction</p>
        </div>
         <div class="filter">
          <div> <i class="fa-solid fa-place-of-worship"></i></div>
          <p>Culture</p>
        </div>
        <div class="filter">
           <div><i class="fa-solid fa-sailboat"></i></div>
          <p>Boating</p>
        </div>
        <div class="filter">
           <div><i class="fa-solid fa-moon"></i></div>
          <p>Nightlife</p>
        </div>
      <div class="tax-toogle"> 
          <div class="form-check form-switch">
          <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
         <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
         </div>
       </div>
    </div>
   
    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1">
        <% for (let listing of allListings) { %>
            <a href="/listings/<%= listing._id  %>" class="listing-link">
       <div class="card listing-card "  style="width: 18rem;">
        <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_image" style="height: 20rem;">
        <div class="card-img-overlay">abcd</div>
        <div class="card-body">
        <p class="card-text">
            <b><%= listing.title  %> </b><br/>
      
            &#x20B9;<%= listing.price.toLocaleString("en-IN")  %>/night
            <i class="tax-info">&nbsp; &nbsp;+18% GST</i>
        </p>
        </div>
       </div>
      <% } %>
    </div>
     
    <script>
    let taxSwitch=document.getElementById("switchCheckDefault");
    taxSwitch.addEventListener("click",()=>{
      let taxInfo=document.getElementsByClassName("tax-info");
      for(info of taxInfo){
        if(info.style.display!="inline"){
          info.style.display="inline";
        }else{
          info.style.display="none";
        }
      }
    });
    </script>
       <!--  <ul>
         <% for (let listing of allListings) { %>
        <li><a href="/listings/<%= listing._id %>"> <%= listing.title  %> </a></li>
        <% } %>
        </ul> -->
</body>
